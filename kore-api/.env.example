# KORE API — Environment Configuration

# API master key (used for admin access)
KORE_API_KEY=dev-test-key-local

# Stripe (optional — leave empty for local-only metering)
STRIPE_SECRET_KEY=

# Billing state file (JSONL local counter)
BILLING_STATE=billing_state.json

# API call log path (for trust card metrics)
API_LOG_FILE=logs/api_calls.jsonl
