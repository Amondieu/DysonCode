{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist/main",
    "rootDir": "src/main",
    "declaration": false,
    "sourceMap": false,
    "lib": ["ES2022"]
  },
  "include": ["src/main/**/*.ts", "src/types/**/*.d.ts"],
  "exclude": ["node_modules", "src/renderer"]
}
