# Grey-OS LiteLLM proxy (port 4000)
LITELLM_BASE_URL=http://127.0.0.1:4000/v1
LITELLM_API_KEY=grey-os-local

# Default model alias exposed by the Grey-OS proxy
KORE_AGENT_MODEL=flash-k2

# Routing mode: local | cloud | hybrid (default: hybrid)
#  local  → llama-swap :8080 with coder (Qwen2.5-Coder-14B local)
#  cloud  → litellm :4000 with flash-k2 (deepseek-v4-flash)
#  hybrid → litellm :4000 primary, llama-swap :8080 fallback
KORE_ROUTING_MODE=hybrid

# Local model endpoint (llama-swap)
KORE_LOCAL_URL=http://127.0.0.1:8080/v1
KORE_LOCAL_API_KEY=sk-local
KORE_LOCAL_MODEL=coder

# Optional direct fallback when the Grey-OS proxy is unavailable
KORE_AGENT_FALLBACK_URL=http://127.0.0.1:8080/v1
KORE_AGENT_FALLBACK_API_KEY=sk-local
KORE_AGENT_FALLBACK_MODEL=SET-A

# Direct cloud API fallback — bypasses local proxy entirely
# Set your DeepSeek API key here: https://platform.deepseek.com/api_keys
KORE_CLOUD_API_KEY=sk-4258c098dec7461e96eb839f72f53208
KORE_CLOUD_API_URL=https://api.deepseek.com/v1
KORE_CLOUD_API_MODEL=deepseek-chat
